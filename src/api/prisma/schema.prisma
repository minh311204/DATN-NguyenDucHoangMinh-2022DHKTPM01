generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum Role {
  ADMIN
  USER
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

/// Yêu cầu hủy booking (chờ admin xử lý / từ chối)
enum BookingCancellationRequestState {
  NONE
  PENDING
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

/// Người lớn (12+) / Trẻ em (5–11, 1/2 giá) / Em bé (<2 tuổi, miễn phí)
enum BookingPassengerAgeCategory {
  ADULT
  CHILD
  INFANT
}

/// Dòng tour (filter UI: Cao cấp / Tiêu chuẩn / Tiết kiệm / Giá tốt)
enum TourLine {
  PREMIUM
  STANDARD
  ECONOMY
  GOOD_VALUE
}

/// Phương tiện chính (Xe / Máy bay / kết hợp)
enum TransportType {
  BUS
  FLIGHT
  MIXED
}

/// Loại nhà cung cấp dịch vụ
enum SupplierType {
  TRANSPORT
  HOTEL
  RESTAURANT
  GUIDE
  ACTIVITY
}

/// Loại phương tiện cụ thể
enum VehicleType {
  CAR_4
  CAR_7
  BUS_16
  BUS_29
  BUS_45
  FLIGHT
  TRAIN
  BOAT
  CABLE_CAR
}

/// Bữa ăn
enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id Int @id @default(autoincrement())

  email        String @unique
  phone        String? @unique
  passwordHash String

  firstName String?
  lastName  String?

  dateOfBirth DateTime?
  avatar      String?

  status UserStatus @default(INACTIVE)
  role   Role       @default(USER)

  invitationToken             String?
  invitationTokenExpiredAtUtc DateTime?

  failedLoginCount Int @default(0)

  emailVerified      Boolean   @default(false)
  emailVerifiedAtUtc DateTime?

  /// false nếu chỉ đăng nhập OAuth (chưa đặt mật khẩu cục bộ)
  hasPassword Boolean @default(true)

  createdAtUtc DateTime @default(now())
  updatedAtUtc DateTime @updatedAt

  // relations
  refreshTokens RefreshToken[]
  resetTokens   ResetPasswordToken[]
  emailVerificationTokens EmailVerificationToken[]
  oauthAccounts OAuthAccount[]

  bookings      Booking[]
  reviews       Review[]
  wishlists     Wishlist[]
  notifications Notification[]
  preference    UserPreference?
  chatSessions  ChatSession[]
  behaviors     UserBehavior[]
}

//////////////////////////////////////////////////
// AUTH
//////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(uuid())

  userId Int
  refreshToken String @unique
  accessTokenJti String
  expiredDateTimeUtc DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BlacklistedAccessToken {
  id Int @id @default(autoincrement())

  userId Int
  jti String

  expiredDateTimeUtc DateTime

  @@index([userId])
}

model ResetPasswordToken {
  id Int @id @default(autoincrement())

  userId Int
  token String @unique
  expiredDateTimeUtc DateTime
  isSentEmail Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model EmailVerificationToken {
  id Int @id @default(autoincrement())

  userId Int
  token  String @unique
  expiredDateTimeUtc DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthAccount {
  id Int @id @default(autoincrement())

  userId Int
  provider       OAuthProvider
  providerUserId String

  createdAtUtc DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

//////////////////////////////////////////////////
// LOCATION
//////////////////////////////////////////////////

model Region {
  id Int @id @default(autoincrement())
  name String?

  provinces Province[]
}

model Province {
  id Int @id @default(autoincrement())
  regionId Int
  name String?

  region Region @relation(fields: [regionId], references: [id])
  locations Location[]
}

model Location {
  id Int @id @default(autoincrement())
  provinceId Int
  name String?
  latitude Decimal?
  longitude Decimal?
  description String?
  isActive Boolean?

  province Province @relation(fields: [provinceId], references: [id])
  toursDeparture   Tour[] @relation("TourDeparture")
  toursDestination Tour[] @relation("TourDestination")
}

//////////////////////////////////////////////////
// TOUR
//////////////////////////////////////////////////

model Tour {
  id Int @id @default(autoincrement())

  /// Điểm khởi hành
  departureLocationId Int
  /// Điểm đến
  destinationLocationId Int

  name String @db.Text
  slug String?
  description String? @db.Text

  durationDays Int?
  basePrice Decimal?
  maxPeople Int?

  thumbnailUrl String?

  ratingAvg Float?
  totalReviews Int?

  /// Dòng tour
  tourLine TourLine?

  /// Phương tiện
  transportType TransportType?

  isActive Boolean?
  /// Hiển thị trong khối Tour nổi bật (trang chủ + /tours?featured=true)
  isFeatured Boolean @default(false)
  createdAtUtc DateTime? @default(now())

  /// Dịch vụ bao gồm (text, VD: "Vé máy bay, KS 4*, ăn sáng...")
  inclusions String? @db.Text
  /// Dịch vụ không bao gồm (text)
  exclusions String? @db.Text
  /// Chính sách hủy tour
  cancellationPolicy String? @db.Text

  /// Phụ thu phòng đơn (VND / suất — mỗi suất áp cho một phòng đơn trong suốt tour)
  singleRoomSupplement Decimal? @db.Decimal(12, 2)

  /// RELATIONS
  departureLocation   Location @relation("TourDeparture", fields: [departureLocationId], references: [id])
  destinationLocation Location @relation("TourDestination", fields: [destinationLocationId], references: [id])

  images      TourImage[]
  promoCodes  PromoCode[]
  videos      TourVideo[]
  schedules   TourSchedule[]
  itineraries TourItinerary[]
  tags        TourTagMapping[]
  reviews     Review[]
  wishlists   Wishlist[]
  transports  TourTransport[]

  embeddings    TourEmbedding[]
  userBehaviors UserBehavior[]

  @@index([departureLocationId])
  @@index([destinationLocationId])
  @@index([tourLine])
  @@index([transportType])
  @@index([basePrice])
}

model TourImage {
  id Int @id @default(autoincrement())
  tourId Int
  imageUrl String
  isThumbnail Boolean?

  tour Tour @relation(fields: [tourId], references: [id])
}

model TourVideo {
  id Int @id @default(autoincrement())
  tourId Int
  videoUrl String

  tour Tour @relation(fields: [tourId], references: [id])
}

model TourSchedule {
  id Int @id @default(autoincrement())

  tourId Int

  startDate DateTime
  endDate DateTime

  availableSeats Int?
  bookedSeats Int?

  priceOverride Decimal?
  status String?

  /** Xóa mềm: ẩn lịch trên site user khi toàn bộ lịch tour đã kết thúc; admin vẫn thấy */
  deletedAt DateTime?

  tour Tour @relation(fields: [tourId], references: [id])

  bookings Booking[]

  @@index([startDate])
  @@index([tourId, startDate])
  @@index([tourId, deletedAt])
}

model TourItinerary {
  id Int @id @default(autoincrement())
  tourId Int

  dayNumber Int
  title String?
  description String? @db.Text

  tour Tour @relation(fields: [tourId], references: [id])

  accommodations TourAccommodation[]
  meals          TourMeal[]
}

model TourTag {
  id Int @id @default(autoincrement())
  name String
  description String? @db.Text

  tours TourTagMapping[]
}

model TourTagMapping {
  tourId Int
  tagId Int

  tour Tour @relation(fields: [tourId], references: [id])
  tag  TourTag @relation(fields: [tagId], references: [id])

  @@id([tourId, tagId])
}

//////////////////////////////////////////////////
// SUPPLIER (Nhà cung cấp dịch vụ)
//////////////////////////////////////////////////

model Supplier {
  id   Int          @id @default(autoincrement())
  name String
  type SupplierType

  phone   String?
  email   String?
  address String?
  website String?
  taxCode String?
  notes   String? @db.Text

  isActive     Boolean   @default(true)
  createdAtUtc DateTime? @default(now())

  transports     TourTransport[]
  accommodations TourAccommodation[]
  meals          TourMeal[]
}

/// Chi tiết từng chặng vận chuyển của tour
model TourTransport {
  id     Int @id @default(autoincrement())
  tourId Int

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  /// Thứ tự chặng (1, 2, 3...)
  legOrder      Int
  vehicleType   VehicleType
  vehicleDetail String?
  seatClass     String?

  departurePoint  String
  arrivalPoint    String
  estimatedHours  Decimal?
  notes           String? @db.Text

  tour Tour @relation(fields: [tourId], references: [id])

  @@index([tourId])
}

/// Khách sạn / lưu trú theo từng ngày lịch trình
model TourAccommodation {
  id          Int @id @default(autoincrement())
  itineraryId Int

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  hotelName    String
  starRating   Int?
  roomType     String?
  checkInNote  String?
  checkOutNote String?
  address      String?
  mapUrl       String?

  itinerary TourItinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

/// Bữa ăn theo từng ngày lịch trình
model TourMeal {
  id          Int @id @default(autoincrement())
  itineraryId Int

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  mealType       MealType
  restaurantName String?
  menuStyle      String?
  dietaryNotes   String?

  itinerary TourItinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////////////////
// PROMO — mã giảm giá (áp khi đặt tour)
//////////////////////////////////////////////////

model PromoCode {
  id Int @id @default(autoincrement())

  /// Mã in HOA, duy nhất
  code String @unique @db.VarChar(64)

  /// Giảm cố định (VND) — dùng nếu set; ưu tiên hơn %
  fixedOff Decimal? @db.Decimal(12, 2)
  /// Giảm % trên subtotal trước giảm (0–100)
  percentOff Decimal? @db.Decimal(5, 2)
  /// Trần tiền giảm khi dùng %
  maxDiscountAmount Decimal? @db.Decimal(12, 2)

  isActive Boolean @default(true)

  validFromUtc DateTime?
  validToUtc   DateTime?

  /// null = mọi tour
  tourId Int?
  tour   Tour? @relation(fields: [tourId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([tourId])
}

//////////////////////////////////////////////////
// BOOKING
//////////////////////////////////////////////////

model Booking {
  id Int @id @default(autoincrement())

  userId Int?
  tourScheduleId Int

  numberOfPeople Int
  bookingDateUtc DateTime? @default(now())
  totalAmount Decimal?

  /// Thông tin liên lạc (người đặt)
  contactFullName String?
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?

  /// Ghi chú thêm
  notes String? @db.Text

  /// Mã giảm giá đã áp dụng (snapshot, uppercase)
  discountCode String? @db.VarChar(64)
  /// Số tiền giảm (VND)
  discountAmount Decimal? @db.Decimal(12, 2)

  /// Số suất phụ thu phòng đơn đã chọn
  singleRoomCount Int @default(0)
  /// Tổng tiền phụ thu phòng đơn tại thời điểm đặt (VND)
  singleRoomSupplementAmount Decimal? @db.Decimal(12, 2)

  status BookingStatus @default(PENDING)
  /// TTL cho trạng thái chờ thanh toán/xử lý
  expiredAtUtc DateTime?

  /// Gửi yêu cầu hủy — chờ admin (trạng thái booking vẫn PENDING/CONFIRMED)
  cancellationRequestState BookingCancellationRequestState @default(NONE)
  cancellationRequestedAtUtc DateTime?
  cancellationRejectedAtUtc  DateTime?
  /// Thời điểm admin chấp nhận hủy (để đối chiếu hoàn tiền / SLA)
  cancellationApprovedAtUtc DateTime?

  user     User?        @relation(fields: [userId], references: [id])
  schedule TourSchedule @relation(fields: [tourScheduleId], references: [id])

  passengers BookingPassenger[]
  payments   Payment[]
  history    BookingStatusHistory[]

  @@index([userId])
  @@index([status, expiredAtUtc])
  @@index([cancellationRequestState])
}

model BookingPassenger {
  id Int @id @default(autoincrement())

  bookingId Int

  ageCategory BookingPassengerAgeCategory

  fullName String
  dateOfBirth DateTime?
  gender String?
  passportNumber String?

  booking Booking @relation(fields: [bookingId], references: [id])
}

model BookingStatusHistory {
  id Int @id @default(autoincrement())

  bookingId Int
  oldStatus BookingStatus?
  newStatus BookingStatus?

  changedAtUtc DateTime? @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id Int @id @default(autoincrement())

  bookingId Int

  paymentGateway String?
  paymentMethod String?
  transactionCode String?

  amount Decimal?

  status PaymentStatus @default(PENDING)
  paidAtUtc DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

//////////////////////////////////////////////////
// SOCIAL
//////////////////////////////////////////////////

model Review {
  id Int @id @default(autoincrement())

  userId Int
  tourId Int

  rating Int
  comment String?

  createdAtUtc DateTime? @default(now())

  user User @relation(fields: [userId], references: [id])
  tour Tour @relation(fields: [tourId], references: [id])

  @@unique([userId, tourId])
}

model Wishlist {
  id Int @id @default(autoincrement())

  userId Int
  tourId Int

  createdAtUtc DateTime? @default(now())

  user User @relation(fields: [userId], references: [id])
  tour Tour @relation(fields: [tourId], references: [id])

  @@unique([userId, tourId])
  @@index([userId])
}

//////////////////////////////////////////////////
// NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id Int @id @default(autoincrement())

  userId Int

  title String?
  content String? @db.Text

  isRead Boolean @default(false)

  createdAtUtc DateTime? @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////////////////////////////////
// USER EXTRA
//////////////////////////////////////////////////

model UserPreference {
  id Int @id @default(autoincrement())

  userId Int @unique

  preferredLocations String?
  budgetRange String?
  travelStyle String?

  user User @relation(fields: [userId], references: [id])
}

//////////////////////////////////////////////////
// CHAT
//////////////////////////////////////////////////

model ChatSession {
  id Int @id @default(autoincrement())

  userId Int?
  /// Dùng cho guest chat: khóa ngẫu nhiên để xác thực session khi không có userId
  sessionKey String? @unique
  startedAtUtc DateTime? @default(now())

  user User? @relation(fields: [userId], references: [id])

  messages ChatMessage[]
}

model ChatMessage {
  id Int @id @default(autoincrement())

  sessionId Int

  role String
  content String @db.LongText

  createdAtUtc DateTime? @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id])
}

//////////////////////////////////////////////////
// AI / TRACKING
//////////////////////////////////////////////////

model TourEmbedding {
  id Int @id @default(autoincrement())

  tourId Int

  embedding String
  contentChunk String?

  tour Tour @relation(fields: [tourId], references: [id])
}

model UserBehavior {
  id Int @id @default(autoincrement())

  userId Int
  tourId Int

  action String
  createdAtUtc DateTime? @default(now())

  user User @relation(fields: [userId], references: [id])
  tour Tour @relation(fields: [tourId], references: [id])
}